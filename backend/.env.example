# ── SentinelAI Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in the values.

# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=sentinelai

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=your-secret-key-here

# ─────────────────────────────────────────────────────────────────────────────
# LEVEL 2 API KEYS (all free tier — fill in to enable each integration)
# ─────────────────────────────────────────────────────────────────────────────

# ── HuggingFace Inference API ─────────────────────────────────────────────────
# Get free token: https://huggingface.co/settings/tokens
# Leave blank → falls back to rule-based toxicity engine
HF_API_KEY=

# ── Google Perspective API ────────────────────────────────────────────────────
# Get free key: https://perspectiveapi.com/
# Leave blank → skipped in detection chain
PERSPECTIVE_API_KEY=

# ── LibreTranslate (Self-Hosted Recommended) ──────────────────────────────────
# Self-host free: docker run -ti --rm -p 5000:5000 libretranslate/libretranslate
# Or use public: https://libretranslate.com (rate limited)
LIBRETRANSLATE_URL=http://localhost:5000
LIBRETRANSLATE_API_KEY=

# ── Reddit API (PRAW) ─────────────────────────────────────────────────────────
# Register free app: https://www.reddit.com/prefs/apps (choose "script" type)
# Leave blank → Reddit stream disabled, simulator runs instead
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=SentinelAI/2.0
# Comma-separated subreddits to monitor:
# REDDIT_SUBREDDITS=["india","teenagers","relationship_advice"]

# ── Discord Bot ───────────────────────────────────────────────────────────────
# Create free bot: https://discord.com/developers/applications
# Enable Message Content Intent in Bot settings
# Leave blank → Discord stream disabled
DISCORD_BOT_TOKEN=
# Comma-separated Guild (server) IDs to monitor (leave blank = monitor all):
# DISCORD_GUILD_IDS=["123456789012345678"]
